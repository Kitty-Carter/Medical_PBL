# ============================================
# Medical PBL 环境变量配置示例
# 复制此文件为 .env 并修改相应配置
# ============================================

# 运行环境
NODE_ENV=production

# 服务端口
PORT=3000

# 教师密码（请务必修改）
TEACHER_PASSWORD=please_change_me

# 会话密钥（请修改为随机字符串）
SESSION_SECRET=please_change_me_to_random_string

# 课堂记录存储路径
RECORDS_ROOT=/opt/medical-pbl-data/records

# AstrBot 集成（可选）
ASTRBOT_ENABLED=false
ASTRBOT_BASE_URL=http://127.0.0.1:6185
ASTRBOT_TIMEOUT_MS=15000

# 公网访问地址
PUBLIC_BASE_URL=http://your-domain-or-ip

# DeepSeek API 配置（如需使用 DeepSeek）
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API 配置（如需使用 OpenAI）
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
