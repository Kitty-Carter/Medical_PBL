{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "TurnPlan": {
      "type": "object",
      "required": ["roleKey", "speechActs", "keyFactCluster", "mainContradiction", "nextActions", "questionOrBranch", "tone", "segmentSpec"],
      "properties": {
        "roleKey": {
          "type": "string",
          "enum": ["teacher", "B", "C"]
        },
        "speechActs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "replyTarget": {
          "type": "object",
          "properties": {
            "speaker": { "type": "string" },
            "snippet": { "type": "string" }
          }
        },
        "keyFactCluster": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": { "type": "string" }
        },
        "mainContradiction": {
          "type": "string"
        },
        "nextActions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string" }
        },
        "questionOrBranch": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        },
        "segmentSpec": {
          "type": "object",
          "properties": {
            "count": { "type": "number" },
            "maxCharsPerSegment": { "type": "number" }
          }
        }
      }
    },
    "Segments": {
      "type": "object",
      "required": ["segments"],
      "properties": {
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "text"],
            "properties": {
              "type": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
